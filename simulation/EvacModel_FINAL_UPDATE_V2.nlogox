    <monitor x="1047" precision="1" y="140" height="60" fontSize="11" width="127" display="avg-panic-level">precision avg-panic-level 1</monitor>
    <plot x="1192" autoPlotX="true" yMax="10.0" autoPlotY="true" yAxis="Remaining" y="10" xMin="0.0" height="164" legend="false" xMax="10.0" yMin="0.0" width="310" xAxis="Time" display="Evacuation Progress">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="Remaining" color="-2674135" legend="true">
        <setup></setup>
        <update>plot count turtles</update>
      </pen>
    </plot>
    <plot x="1191" autoPlotX="true" yMax="10.0" autoPlotY="true" yAxis="Average Panic Level" y="186" xMin="0.0" height="177" legend="false" xMax="10.0" yMin="0.0" width="311" xAxis="Time (seconds)" display="Panic Levels Over Time">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="Avg Panic" color="-16777216" legend="true">
        <setup></setup>
        <update>plot avg-panic-level</update>
      </pen>
    </plot>
    <plot x="1191" autoPlotX="true" yMax="10.0" autoPlotY="true" yAxis="Congestion Level" y="376" xMin="0.0" height="158" legend="false" xMax="10.0" yMin="0.0" width="311" xAxis="Time (seconds)" display="Congestion Events">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="Max Congestion" color="-16777216" legend="true">
        <setup></setup>
        <update>plot max-congestion-level</update>
      </pen>
    </plot>
    <monitor x="904" precision="17" y="10" height="60" fontSize="11" width="129" display="Max Congestion">max-congestion-level</monitor>
    <chooser x="898" y="351" height="60" variable="lecture-hall-layout" current="5" width="140" display="lecture-hall-layout">
      <choice type="string" value="traditional"></choice>
      <choice type="string" value="center-side-aisle"></choice>
      <choice type="string" value="center-aisle-only"></choice>
      <choice type="string" value="tiered"></choice>
      <choice type="string" value="side-exits-hall"></choice>
      <choice type="string" value="wide-auditorium"></choice>
    </chooser>
    <switch x="904" y="419" height="40" on="false" variable="exit-blockage?" width="128" display="exit-blockage?"></switch>
    <chooser x="899" y="283" height="60" variable="evacuation-behavior" current="4" width="139" display="evacuation-behavior">
      <choice type="string" value="calm-and-orderly"></choice>
      <choice type="string" value="panic-rush"></choice>
      <choice type="string" value="follow-others"></choice>
      <choice type="string" value="nearest-exit"></choice>
      <choice type="string" value="mixed-population"></choice>
    </chooser>
    <monitor x="904" precision="17" y="78" height="60" fontSize="11" width="129" display="Bottleneck Locations">length bottleneck-locations</monitor>
    <monitor x="904" precision="17" y="213" height="60" fontSize="11" width="129">evacuation-started?</monitor>
    <monitor x="904" precision="17" y="145" height="60" fontSize="11" width="129">congestion-events</monitor>
    <slider x="716" step="1" y="10" max="200" width="172" display="number-of-students" height="50" min="10" direction="Horizontal" default="200.0" variable="number-of-students"></slider>
    <slider x="712" step="0.1" y="360" max="1.9" width="180" display="exit-capacity-per-meter" height="50" min="1.3" direction="Horizontal" default="1.6" variable="exit-capacity-per-meter"></slider>
    <slider x="716" step="1" y="127" max="50" width="172" display="alarm-time" height="50" min="5" direction="Horizontal" default="5.0" variable="alarm-time"></slider>
    <slider x="716" step="1" y="68" max="50" width="172" display="initial-panic-level" height="50" min="0" direction="Horizontal" default="0.0" variable="initial-panic-level"></slider>
    <slider x="716" step="1" y="243" max="10" width="172" display="percent-impaired" height="50" min="0" direction="Horizontal" default="1.0" variable="percent-impaired"></slider>
    <slider x="716" step="1" y="302" max="3" width="172" display="exit-width" height="50" min="1" direction="Horizontal" default="2.0" variable="exit-width"></slider>
    <slider x="716" step="1" y="185" max="100" width="172" display="familiarity-percentage" height="50" min="0" direction="Horizontal" default="50.0" variable="familiarity-percentage"></slider>
  </widgets>
